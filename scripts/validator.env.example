#!/usr/bin/env bash
# Copy to scripts/validator.env and edit values before running:
#   cp scripts/validator.env.example scripts/validator.env
#   bash ./scripts/run_validator.sh

# Required wallet fields
WALLET_NAME="validator"
WALLET_HOTKEY="default"

# Network
NETUID="26"
NETWORK="finney"

# Optional Python and extra CLI flags
PYTHON_BIN="python3"
LOG_LEVEL="DEBUG"
VALIDATOR_EXTRA_ARGS=""

# Optional: Hugging Face token for faster, higher-rate-limit dataset downloads.
HF_TOKEN=""

# Optional product integrations. Disabled by default; set to true to opt in.
PERTURB_LEADERBOARD_ENABLED="false"

# Task / response API
PERTURB_API_KEY=""
