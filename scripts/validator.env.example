#!/usr/bin/env bash
# Copy to scripts/validator.env and edit values before running:
#   cp scripts/validator.env.example scripts/validator.env
#   bash ./scripts/run_validator.sh

# Required wallet fields
WALLET_NAME="validator"
WALLET_HOTKEY="default"

# Network
NETUID="1"
NETWORK="finney"

# Optional Python and extra CLI flags
PYTHON_BIN="python3"
LOG_LEVEL="DEBUG"
VALIDATOR_EXTRA_ARGS=""

export PERTURB_IMAGENET100_ROOT="assets/imagenet-100"
export PERTURB_IMAGENET100_MANIFEST=""
export PERTURB_IMAGENET100_AUTO_DOWNLOAD="true"
export PERTURB_IMAGENET100_REPO_ID="clane9/imagenet-100"
export PERTURB_IMAGENET100_SPLIT="train"
# Optional: Hugging Face token for faster, higher-rate-limit dataset downloads.
# export HF_TOKEN=""
export PERTURB_IMAGENET100_MAX_IMAGES="5000"
export PERTURB_IMAGENET100_MIN_IMAGES="1000"
export PERTURB_WANDB_ENABLED="false"
export WANDB_API_KEY=""