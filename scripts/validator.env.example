#!/usr/bin/env bash
# Copy to scripts/validator.env and edit values before running:
#   cp scripts/validator.env.example scripts/validator.env
#   bash ./scripts/run_validator.sh

# Required wallet fields
WALLET_NAME="validator"
WALLET_HOTKEY="default"

# Network
NETUID="26"
NETWORK="finney"

# Optional Python and extra CLI flags
PYTHON_BIN="python3"
LOG_LEVEL="DEBUG"
VALIDATOR_EXTRA_ARGS=""

# Optional: Hugging Face token for faster, higher-rate-limit dataset downloads.
HF_TOKEN=""

# Optional product integrations. Disabled by default; set to true to opt in.
PERTURB_RESPONSE_STORAGE_ENABLED="false"
PERTURB_LEADERBOARD_ENABLED="false"

# Optional: upload successful miner adversarial responses.
PERTURB_RESPONSE_STORAGE_BACKEND="r2"   # r2 or hippius
PERTURB_STORAGE_MODE="latest"          # latest or all

# Cloudflare R2 storage (default backend).
PERTURB_R2_BUCKET=""
PERTURB_R2_ENDPOINT_URL=""          # https://<account-id>.r2.cloudflarestorage.com
PERTURB_R2_ACCESS_KEY_ID=""
PERTURB_R2_SECRET_ACCESS_KEY=""

# Hippius S3-compatible storage (set PERTURB_RESPONSE_STORAGE_BACKEND="hippius").
PERTURB_HIPPIUS_BUCKET=""
PERTURB_HIPPIUS_ACCESS_KEY_ID=""
PERTURB_HIPPIUS_SECRET_ACCESS_KEY=""
PERTURB_HIPPIUS_ENDPOINT_URL="https://s3.hippius.com"
PERTURB_HIPPIUS_REGION="decentralized"