#!/usr/bin/env bash
# Copy to scripts/miner.env and edit values before running:
#   cp scripts/miner.env.example scripts/miner.env
#   bash ./scripts/run_miner.sh

# Required
WALLET_NAME="miner"
WALLET_HOTKEY="default"

# Network
NETUID="1"
NETWORK="finney"
SUBTENSOR_CHAIN_ENDPOINT=""

# Optional
PYTHON_BIN="python3"
LOG_LEVEL="DEBUG"
MINER_EXTRA_ARGS=""

# Miner uploads its perturbed response image before submitting the URL.
PERTURB_STORAGE_BACKEND="hippius"   # hippius or r2
PERTURB_STORAGE_BUCKET=""
PERTURB_STORAGE_ACCESS_KEY_ID=""
PERTURB_STORAGE_SECRET_ACCESS_KEY=""
PERTURB_STORAGE_ENDPOINT_URL=""     # optional for hippius; required for r2
PERTURB_STORAGE_REGION=""           # optional; hippius defaults to decentralized, r2 defaults to auto
